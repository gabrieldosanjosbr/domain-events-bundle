{
  "name": "gabrieldosanjosbr/domain-events-bundle",
  "description": "Simple domain events for Symfony using Doctrine",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "GabrielDosAnjosBr\\DomainEvents\\": "src/"
    }
  },
  "authors": [
    {
      "name": "Gabriel dos Anjos",
      "email": "gabrieldosanjos@outlook.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "symfony/event-dispatcher": "^6.4|^7.0",
    "symfony/dependency-injection": "^6.4|^7.0",
    "symfony/config": "^6.4|^7.0",
    "symfony/http-kernel": "^6.4|^7.0",
    "doctrine/persistence": "^3.0 || ^4.0"
  },
  "minimum-stability": "stable",
  "suggest": {
    "doctrine/orm": "Required for ORM domain events support",
    "doctrine/mongodb-odm": "Required for MongoDB domain events support"
  }
}